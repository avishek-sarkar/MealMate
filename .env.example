# ============================================================================
# MealMate Environment Configuration Template
# ============================================================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Update the values below with your actual configuration
# 3. Never commit the .env file to git!
#

# Flask Configuration
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=True

# Security (REQUIRED - Generate a secure random key)
SECRET_KEY=your-super-secret-key-change-this-in-production

# Database Configuration (for future implementation)
# DATABASE_URL=sqlite:///mealmate.db
# DATABASE_URL=postgresql://user:password@localhost/mealmate

# Email Configuration (for future features)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your-email@example.com
# MAIL_PASSWORD=your-app-password

# External API Keys (for future features)
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key
# CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
# CLOUDINARY_API_KEY=your-cloudinary-api-key
# CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Payment Gateway (for future marketplace features)
# STRIPE_PUBLIC_KEY=pk_test_your-stripe-public-key
# STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# Redis (for future caching/sessions)
# REDIS_URL=redis://localhost:6379/0